    {
      "id": "creamy-chicken-sausage-orzo-skillet",
      "name": "Creamy Chicken Sausage Orzo Skillet",
      "mealTypes": ["Dinner"],
      "easy": false,
      "servings": 4,
      "notes": "Cook sausage in olive oil over medium-high heat, 6-7 min, until browned. Add garlic, saute 30 sec. Add orzo, toast 60 sec. Pour in broth to deglaze, then add coconut milk, soy sauce, seasonings, and thyme. Bring to a boil, cover, reduce heat, and simmer 10-12 min, stirring occasionally, until orzo is tender and liquid is absorbed. Stir in spinach until wilted, then mix in parmesan. Season with extra salt and pepper to taste.\n\nSource: https://www.eatyourselfskinny.com/creamy-chicken-sausage-orzo-skillet/",
      "ingredients": [
        { "name": "Olive oil", "qty": 1, "unit": "tbsp" },
