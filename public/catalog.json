    {
      "id": "tex-mex-beef-black-bean-casserole",
      "name": "Tex-Mex Beef & Black Bean Casserole",
      "mealTypes": ["Dinner"],
      "easy": false,
      "servings": 6,
      "notes": "Preheat oven to 375F. Heat olive oil in an oven-safe skillet and cook onion until softened, about 4 min; add garlic and cook 1 min more. Add beef and cook until browned, breaking it up, then drain fat and stir in taco seasoning. Stir in black beans, corn, Rotel, and enchilada sauce; simmer 3-4 min. Layer half the beef mixture, tortilla strips, and cheese in a 9x13 dish; repeat layers. Bake uncovered 20-25 min until bubbly. Rest 5 min, then serve with sour cream.",
      "ingredients": [
        { "name": "Ground beef", "qty": 1.5, "unit": "lb" },
        { "name": "Yellow onion", "qty": 1, "unit": "" },
        { "name": "Garlic", "qty": 3, "unit": "cloves" },
        { "name": "Black beans", "qty": 1, "unit": "can (15 oz)" },
        { "name": "Corn", "qty": 1, "unit": "can (15 oz)" },
        { "name": "Diced tomatoes with green chiles (Rotel)", "qty": 1, "unit": "can (10 oz)" },
        { "name": "Red enchilada sauce", "qty": 1, "unit": "can (10 oz)" },
        { "name": "Mexican blend cheese", "qty": 2, "unit": "cups" },
        { "name": "Corn tortillas", "qty": 8, "unit": "" },
        { "name": "Taco seasoning", "qty": 2, "unit": "packets" },
        { "name": "Olive oil", "qty": 1, "unit": "tbsp" },
        { "name": "Sour cream", "qty": 0.5, "unit": "cup" }
      ]
    },
    {
      "id": "lemon-herb-salmon-asparagus-sheet-pan",
      "name": "Lemon Herb Salmon & Asparagus Sheet Pan",
      "mealTypes": ["Dinner"],
      "easy": false,
      "servings": 4,
      "notes": "Preheat oven to 400F and line a sheet pan with parchment. Toss asparagus with half the olive oil, salt, and pepper, and spread on one half of the pan. Whisk the remaining olive oil, garlic, Dijon, juice of one lemon, dill/parsley, salt, and pepper. Place salmon on the other half of the pan, spoon sauce over the fillets, top with capers, and lay slices from the second lemon over top. Roast 12-15 min until salmon flakes easily and asparagus is lightly crispy.",
      "ingredients": [
        { "name": "Salmon fillets", "qty": 4, "unit": "fillets (6 oz ea)" },
        { "name": "Asparagus", "qty": 1.5, "unit": "lb" },
        { "name": "Lemon", "qty": 2, "unit": "" },
        { "name": "Garlic", "qty": 3, "unit": "cloves" },
        { "name": "Olive oil", "qty": 3, "unit": "tbsp" },
        { "name": "Fresh dill or parsley", "qty": 3, "unit": "tbsp" },
        { "name": "Dijon mustard", "qty": 1, "unit": "tbsp" },
        { "name": "Capers (optional)", "qty": 1, "unit": "tbsp" },
        { "name": "Salt", "qty": 1, "unit": "tsp" },
        { "name": "Black pepper", "qty": 0.5, "unit": "tsp" }
      ]
    },
    {
      "id": "herb-roasted-pork-loin-potatoes-carrots",
      "name": "One-Pan Herb Roasted Pork Loin with Potatoes & Carrots",
      "mealTypes": ["Dinner"],
      "easy": true,
      "servings": 6,
      "notes": "Preheat oven to 425F and pat pork dry. Rub pork with a mix of Dijon, garlic, salt, and pepper. Toss potatoes and carrots with olive oil, salt, and pepper directly in a roasting pan. Sear pork on all sides in the remaining oil, about 2 min per side, then nestle into the vegetables. Lay rosemary and thyme sprigs over top and pour chicken broth into the pan. Roast uncovered 45-55 min until pork reaches 145F internal and vegetables are golden. Rest pork 10 min before slicing; serve with pan juices.",
      "ingredients": [
        { "name": "Pork loin roast", "qty": 2.5, "unit": "lb" },
        { "name": "Baby potatoes", "qty": 1.5, "unit": "lb" },
        { "name": "Carrots", "qty": 4, "unit": "" },
        { "name": "Olive oil", "qty": 4, "unit": "tbsp" },
        { "name": "Garlic", "qty": 4, "unit": "cloves" },
        { "name": "Rosemary", "qty": 3, "unit": "sprigs" },
        { "name": "Thyme", "qty": 4, "unit": "sprigs" },
        { "name": "Chicken broth", "qty": 0.5, "unit": "cup" },
        { "name": "Dijon mustard", "qty": 2, "unit": "tbsp" },
        { "name": "Salt", "qty": 1.5, "unit": "tsp" },
        { "name": "Black pepper", "qty": 1, "unit": "tsp" }
      ]
    },
