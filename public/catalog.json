    {
      "id": "vanilla-marshmallow-boob-cake",
      "name": "One-Year Breastfeeding Cake (Vanilla Marshmallow \"Boob Cake\")",
      "mealTypes": [],
      "easy": false,
      "servings": 12,
      "notes": "Preheat oven to 350F; grease and line two 8-9in round pans. Whisk flour, baking powder, and salt. Cream butter and granulated sugar 2-3 min until fluffy, then mix in egg whites and vanilla. Alternate adding the flour mixture and milk in three additions, mixing just until combined. Divide batter into pans and bake 25-30 min; cool completely. For the filling, whip the cream with powdered sugar to soft peaks, then fold in marshmallow fluff and vanilla; chill. Stack the cooled cakes, carve a center hole leaving about a 1in base, fill with marshmallow filling, and replace the top piece; carve into a smooth dome. For the buttercream, beat the butter, then gradually add powdered sugar, milk/cream, vanilla, and a pinch of salt until fluffy. Apply a thin crumb coat and chill 20-30 min, then frost smoothly into a dome shape. Tint a small amount of frosting pink and pipe a circle in the center. Refrigerate up to 3 days; bring to room temp before serving.",
      "ingredients": [
        { "name": "'1' candle", "qty": 1, "unit": "" },
        { "name": "All-purpose flour", "qty": 2.5, "unit": "cups" },
        { "name": "Baking powder", "qty": 2.5, "unit": "tsp" },
        { "name": "Salt", "qty": 0.5, "unit": "tsp (plus a pinch)" },
        { "name": "Granulated sugar", "qty": 1.75, "unit": "cups" },
        { "name": "Powdered sugar", "qty": 4, "unit": "cups (about)" },
        { "name": "Unsalted butter", "qty": 3, "unit": "sticks" },
        { "name": "Milk", "qty": 1, "unit": "cup" },
        { "name": "Heavy whipping cream", "qty": 0.5, "unit": "cup" },
        { "name": "Eggs", "qty": 1, "unit": "dozen" },
        { "name": "Vanilla extract", "qty": 1.5, "unit": "tbsp" },
        { "name": "Marshmallow fluff", "qty": 1, "unit": "jar (7-8 oz)" },
        { "name": "Pink food coloring", "qty": 1, "unit": "bottle" }
      ]
    },
    {
      "id": "baked-cod-lemon-garlic",
      "name": "Baked Cod with Lemon and Garlic",
      "mealTypes": ["Dinner"],
      "easy": false,
      "servings": 5,
      "notes": "Preheat oven to 400F. Mix lemon juice, olive oil, and melted butter in a shallow bowl (no garlic yet); set aside. In another shallow bowl, mix flour, coriander, paprika, cumin, salt, and pepper. Pat fish dry, dip in the lemon sauce then the flour mixture, shaking off excess; reserve the remaining lemon sauce. Heat 2 tbsp olive oil in a cast iron or oven-safe skillet over medium-high and sear fish about 2 min per side for color, then remove from heat. Stir the minced garlic into the reserved lemon sauce and drizzle over the fish. Bake until the fish flakes easily, about 10 min. Sprinkle with parsley and serve immediately.\n\nSource: https://www.themediterraneandish.com/baked-cod-recipe-lemon-garlic/",
      "ingredients": [
        { "name": "Cod fillets", "qty": 1.5, "unit": "lb" },
        { "name": "Lemon juice", "qty": 5, "unit": "tbsp" },
        { "name": "Olive oil", "qty": 7, "unit": "tbsp" },
        { "name": "Butter", "qty": 2, "unit": "tbsp" },
        { "name": "Garlic", "qty": 5, "unit": "cloves" },
        { "name": "All-purpose flour", "qty": 0.33, "unit": "cups" },
        { "name": "Ground coriander", "qty": 1, "unit": "tsp" },
        { "name": "Paprika", "qty": 0.75, "unit": "tsp" },
        { "name": "Ground cumin", "qty": 0.75, "unit": "tsp" },
        { "name": "Salt", "qty": 0.75, "unit": "tsp" },
        { "name": "Black pepper", "qty": 0.5, "unit": "tsp" }
      ]
    },
    {
      "id": "baked-chicken-veggie-meatballs",
      "name": "Baked Chicken & Veggie Meatballs",
      "mealTypes": ["Lunch", "Dinner"],
      "easy": false,
      "servings": 4,
      "notes": "Yields about 24-30 1-inch meatballs (age 6 months+). \nPreheat oven to 400F and line a baking sheet with parchment. Shred the carrots. Chop the spinach. Chop the green onion. Combine all ingredients in a large bowl and gently fold together until just incorporated; let sit 5 min. Roll into 1-inch balls, wetting hands as needed. Bake 15-20 min until cooked through and lightly browned. Let cool and serve. Season with salt and pepper to taste. Store in the fridge up to 4 days or freezer up to 3 months.\n\nSource: https://babyfoode.com/blog/mini-chicken-carrot-meatballs-for-baby/",
      "ingredients": [
        { "name": "Ground chicken", "qty": 1, "unit": "lb" },
        { "name": "Applesauce", "qty": 0.25, "unit": "cup" },
        { "name": "Carrots", "qty": 0.5, "unit": "cup" },
        { "name": "Spinach", "qty": 0.5, "unit": "cup" },
        { "name": "Green onion", "qty": 0.25, "unit": "cup" },
        { "name": "Eggs", "qty": 1, "unit": "" },
        { "name": "Breadcrumbs", "qty": 0.5, "unit": "cup" },
        { "name": "Olive oil", "qty": 1, "unit": "tbsp" },
        { "name": "Ground cumin", "qty": 0.5, "unit": "tsp" }
      ]
    },
